TELEGRAM_BOT_TOKEN=isi_token_bot_telegram_kamu
DEEPSEEK_API_KEY=isi_api_key_deepseek_kamu

# Model: deepseek-v4-flash (cepat & murah, default) atau deepseek-v4-pro (lebih kuat, lebih mahal)
# Catatan: nama lama "deepseek-chat" / "deepseek-reasoner" akan di-retire 24 Juli 2026.
DEEPSEEK_MODEL=deepseek-v4-flash

# Bahasa untuk OCR gambar. Default Inggris+Indonesia.
OCR_LANGS=eng+ind
